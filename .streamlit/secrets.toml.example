# 复制为 .streamlit/secrets.toml（已在 .gitignore）
# Streamlit Cloud：在 App Settings → Secrets 粘贴相同结构
# 密码可写明文，程序加载时会自动 bcrypt 哈希

DASHSCOPE_API_KEY = "sk-your-dashscope-key"

[credentials.usernames.alice]
email = "alice@example.com"
name = "Alice"
password = "change-me"

[credentials.usernames.bob]
email = "bob@example.com"
name = "Bob"
password = "change-me"

[credentials.usernames.carol]
email = "carol@example.com"
name = "Carol"
password = "change-me"

[cookie]
name = "amazon_ad_auth"
key = "replace-with-a-long-random-string"
expiry_days = 30

# Turso 云端 SQLite（每人一库）；本地开发不配此项则仍用 user_dict/*.db
[turso.databases]
alice = "libsql://ad-history-alice-yourorg.aws-us-east-1.turso.io"
bob = "libsql://ad-history-bob-yourorg.aws-us-east-1.turso.io"
carol = "libsql://ad-history-carol-yourorg.aws-us-east-1.turso.io"

[turso.tokens]
alice = "eyJ..."
bob = "eyJ..."
carol = "eyJ..."

# 可选：所有库共用一个 group token 时，可只配 auth_token 而不配 turso.tokens
# [turso]
# auth_token = "eyJ..."
