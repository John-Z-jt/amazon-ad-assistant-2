# 复制为 config/credentials.yaml（该文件已在 .gitignore 中忽略）
# 本地开发：只维护本文件即可，无需 .streamlit/secrets.toml
# 上云：可用 .streamlit/secrets.toml 或平台 secrets 代替本文件
# 密码可写明文，程序加载时会自动 bcrypt 哈希

credentials:
  usernames:
    alice:
      email: alice@example.com
      name: Alice
      password: AmazonAd2026!
    bob:
      email: bob@example.com
      name: Bob
      password: AmazonAd2026!
    carol:
      email: carol@example.com
      name: Carol
      password: AmazonAd2026!

cookie:
  name: amazon_ad_auth
  key: replace-with-a-long-random-string
  expiry_days: 30
